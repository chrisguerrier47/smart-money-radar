# ─── Database (Docker handles this locally, Railway auto-generates in prod) ───
DATABASE_URL=postgresql://postgres:password@db:5432/smartmoney

# ─── LLM ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Data Sources ─────────────────────────────────────────────────────────────
# SEC EDGAR - free, just your email
SEC_USER_AGENT=your@email.com

# Finnhub - free tier at finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key

# ─── Signal Config ────────────────────────────────────────────────────────────
CLUSTER_WINDOW_DAYS=30
MIN_SCORE_THRESHOLD=40

# ─── App ──────────────────────────────────────────────────────────────────────
ENV=development
CORS_ORIGINS=http://localhost:5173
